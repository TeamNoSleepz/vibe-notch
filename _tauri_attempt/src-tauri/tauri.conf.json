{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notch-agent",
  "version": "0.0.1",
  "identifier": "com.notchagent.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "notch",
        "title": "notch-agent",
        "width": 300,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
